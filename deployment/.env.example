# Database
DATABASE_URL=postgresql://incidentiq:CHANGE_ME@postgres:5432/incidentiq
POSTGRES_DB=incidentiq
POSTGRES_USER=incidentiq
POSTGRES_PASSWORD=CHANGE_ME

# Session
SESSION_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# App
APP_URL=https://incidentiq.io
ALLOWED_ORIGINS=https://incidentiq.io

# VAPID (Web Push) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@incidentiq.io

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@incidentiq.io
SMTP_PASS=
SMTP_FROM=noreply@incidentiq.io
