# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/groupwatch

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_URL=https://groupwatchplatform.com

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@groupwatchplatform.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@groupwatchplatform.com

# ── Web Push (VAPID) ───────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@groupwatchplatform.com

# ── GitHub Actions secrets required ───────────────────────────────────────────
# VPS_HOST       — VPS IP or hostname
# VPS_USER       — SSH user (e.g. ubuntu)
# VPS_SSH_KEY    — Private SSH key (contents of ~/.ssh/id_rsa)
# DATABASE_URL   — Production database URL (used by migrator)
# GITHUB_TOKEN   — Auto-provided by GitHub Actions
